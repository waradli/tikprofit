<%- include('partials/header') %>
<div class="page-header">
  <h4><i class="bi bi-box-seam"></i> Data Produk</h4>
  <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#addModal"><i class="bi bi-plus-lg"></i> Tambah Produk</button>
</div>

<div class="card">
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead>
          <tr>
            <th>Nama</th>
            <th>Kategori</th>
            <th>Modal</th>
            <th>Harga Jual</th>
            <th>Stok</th>
            <th class="text-center">Aksi</th>
          </tr>
        </thead>
        <tbody>
          <% if(products.length === 0) { %>
            <tr><td colspan="6">
              <div class="empty-state">
                <i class="bi bi-box"></i>
                <p class="text-muted mb-0">Belum ada produk. Klik "Tambah Produk" untuk memulai.</p>
              </div>
            </td></tr>
          <% } %>
          <% products.forEach(p => { %>
          <tr>
            <td class="fw-semibold"><%= p.name %></td>
            <td><span class="badge bg-light text-dark"><%= p.category || '-' %></span></td>
            <td>Rp <%= Number(p.modal).toLocaleString('id-ID') %></td>
            <td>Rp <%= Number(p.harga_jual).toLocaleString('id-ID') %></td>
            <td><span class="badge bg-<%= p.stok > 0 ? 'success' : 'danger' %>"><%= p.stok %></span></td>
            <td class="text-center">
              <button class="btn btn-sm btn-warning btn-action" data-bs-toggle="modal" data-bs-target="#editModal<%= p.id %>" title="Edit"><i class="bi bi-pencil"></i></button>
              <form method="POST" action="/products/delete/<%= p.id %>" class="d-inline" onsubmit="return confirm('Hapus produk?')">
                <button class="btn btn-sm btn-danger btn-action"><i class="bi bi-trash"></i></button>
              </form>
            </td>
          </tr>

          <div class="modal fade" id="editModal<%= p.id %>">
            <div class="modal-dialog">
              <div class="modal-content">
                <form method="POST" action="/products/edit/<%= p.id %>">
                  <div class="modal-header"><h5 class="modal-title"><i class="bi bi-pencil-square text-warning"></i> Edit Produk</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
                  <div class="modal-body">
                    <div class="mb-3"><label class="form-label">Nama Produk</label><input class="form-control" name="name" value="<%= p.name %>" required></div>
                    <div class="mb-3"><label class="form-label">Kategori</label><input class="form-control" name="category" value="<%= p.category %>"></div>
                    <div class="row g-2">
                      <div class="col-6"><label class="form-label">Modal</label><input class="form-control" name="modal" type="number" step="0.01" value="<%= p.modal %>" required></div>
                      <div class="col-6"><label class="form-label">Harga Jual</label><input class="form-control" name="harga_jual" type="number" step="0.01" value="<%= p.harga_jual %>" required></div>
                    </div>
                    <div class="mb-2"><label class="form-label">Stok</label><input class="form-control" name="stok" type="number" value="<%= p.stok %>" required></div>
                  </div>
                  <div class="modal-footer">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Batal</button>
                    <button class="btn btn-primary">Simpan Perubahan</button>
                  </div>
                </form>
              </div>
            </div>
          </div>
        <% }); %>
      </tbody>
    </table>
  </div>
</div>

<div class="modal fade" id="addModal">
  <div class="modal-dialog">
    <div class="modal-content">
      <form method="POST" action="/products">
        <div class="modal-header"><h5 class="modal-title"><i class="bi bi-plus-circle text-primary"></i> Tambah Produk</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
        <div class="modal-body">
          <div class="mb-3"><label class="form-label">Nama Produk</label><input class="form-control" name="name" placeholder="Masukkan nama produk" required></div>
          <div class="mb-3"><label class="form-label">Kategori</label><input class="form-control" name="category" placeholder="Contoh: Fashion, Elektronik"></div>
          <div class="row g-2 mb-3">
            <div class="col-6"><label class="form-label">Modal (Rp)</label><input class="form-control" name="modal" type="number" step="0.01" placeholder="0" required></div>
            <div class="col-6"><label class="form-label">Harga Jual (Rp)</label><input class="form-control" name="harga_jual" type="number" step="0.01" placeholder="0" required></div>
          </div>
          <div class="mb-2"><label class="form-label">Stok Awal</label><input class="form-control" name="stok" type="number" placeholder="0" required></div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-light" data-bs-dismiss="modal">Batal</button>
          <button class="btn btn-primary"><i class="bi bi-check-lg"></i> Simpan</button>
        </div>
      </form>
    </div>
  </div>
</div>
<%- include('partials/footer') %>