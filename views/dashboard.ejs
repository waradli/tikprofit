<%- include('partials/header') %>
<div class="page-header">
  <h4><i class="bi bi-speedometer2"></i> Dashboard Keuangan</h4>
  <span class="text-muted" style="font-size:0.8rem;"><i class="bi bi-calendar3"></i> <%= new Date().toLocaleDateString('id-ID', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %></span>
</div>

<div class="row g-3 mb-4">
  <div class="col-6 col-md-3 col-lg">
    <div class="card stat-card stat-card-success h-100">
      <div class="card-body text-center">
        <div class="stat-icon"><i class="bi bi-piggy-bank"></i></div>
        <div class="stat-value">Rp <%= Number(totalKas).toLocaleString('id-ID') %></div>
        <div class="stat-label">Total Kas</div>
      </div>
    </div>
  </div>
  <div class="col-6 col-md-3 col-lg">
    <div class="card stat-card stat-card-primary h-100">
      <div class="card-body text-center">
        <div class="stat-icon"><i class="bi bi-cash-stack"></i></div>
        <div class="stat-value">Rp <%= Number(totalPemasukan.total).toLocaleString('id-ID') %></div>
        <div class="stat-label">Pemasukan Harian</div>
      </div>
    </div>
  </div>

  <div class="col-6 col-md-3 col-lg">
    <div class="card stat-card stat-card-secondary h-100">
      <div class="card-body text-center">
        <div class="stat-icon"><i class="bi bi-calculator"></i></div>
        <div class="stat-value">Rp <%= Number(totalModal.total).toLocaleString('id-ID') %></div>
        <div class="stat-label">Total Modal</div>
      </div>
    </div>
  </div>
  <div class="col-6 col-md-3 col-lg">
    <div class="card stat-card stat-card-info h-100">
      <div class="card-body text-center">
        <div class="stat-icon"><i class="bi bi-graph-up-arrow"></i></div>
        <div class="stat-value">Rp <%= Number(totalMargin.total).toLocaleString('id-ID') %></div>
        <div class="stat-label">Total Margin</div>
      </div>
    </div>
  </div>
  <div class="col-6 col-md-3 col-lg">
    <div class="card stat-card stat-card-danger h-100">
      <div class="card-body text-center">
        <div class="stat-icon"><i class="bi bi-box-arrow-right"></i></div>
        <div class="stat-value">Rp <%= Number(totalPengeluaran.total).toLocaleString('id-ID') %></div>
        <div class="stat-label">Total Pengeluaran</div>
      </div>
    </div>
  </div>
</div>

<div class="row g-3 mb-4">
  <div class="col-md-6">
    <div class="card chart-card">
      <div class="card-header">
        <h6 class="mb-0"><i class="bi bi-graph-up text-primary"></i> Grafik Pemasukan & Margin</h6>
      </div>
      <div class="card-body">
        <canvas id="financialChart" height="200"></canvas>
      </div>
    </div>
  </div>
  <div class="col-md-6">
    <div class="card chart-card">
      <div class="card-header">
        <h6 class="mb-0"><i class="bi bi-graph-down text-danger"></i> Grafik Pengeluaran</h6>
      </div>
      <div class="card-body">
        <canvas id="pengeluaranChart" height="200"></canvas>
      </div>
    </div>
  </div>
</div>

<script>
const financialData = <%- JSON.stringify(financialByDate) %>;
const pengeluaranData = <%- JSON.stringify(pengeluaranByDate) %>;

new Chart(document.getElementById('financialChart'), {
  type: 'line',
  data: {
    labels: financialData.map(d => d.tanggal),
    datasets: [
      { label: 'Pemasukan', data: financialData.map(d => d.uang_masuk), borderColor: '#6C5CE7', backgroundColor: 'rgba(108,92,231,0.1)', fill: true, tension: 0.4, pointRadius: 3, pointBackgroundColor: '#6C5CE7' },
      { label: 'Margin', data: financialData.map(d => d.margin), borderColor: '#00B894', backgroundColor: 'rgba(0,184,148,0.1)', fill: true, tension: 0.4, pointRadius: 3, pointBackgroundColor: '#00B894' }
    ]
  },
  options: {
    responsive: true,
    plugins: { legend: { position: 'top', labels: { usePointStyle: true, padding: 15 } } },
    scales: { y: { beginAtZero: true, grid: { color: 'rgba(0,0,0,0.04)' } }, x: { grid: { display: false } } }
  }
});

new Chart(document.getElementById('pengeluaranChart'), {
  type: 'bar',
  data: {
    labels: pengeluaranData.map(d => d.tanggal),
    datasets: [
      { label: 'Pengeluaran', data: pengeluaranData.map(d => d.total), backgroundColor: 'rgba(225,112,85,0.7)', borderColor: '#E17055', borderWidth: 1, borderRadius: 4 }
    ]
  },
  options: {
    responsive: true,
    plugins: { legend: { position: 'top', labels: { usePointStyle: true, padding: 15 } } },
    scales: { y: { beginAtZero: true, grid: { color: 'rgba(0,0,0,0.04)' } }, x: { grid: { display: false } } }
  }
});
</script>
<%- include('partials/footer') %>
