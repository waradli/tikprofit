<%- include('partials/header') %>
<div class="page-header">
  <h4><i class="bi bi-journal-text"></i> Transaksi Harian</h4>
  <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#addModal"><i class="bi bi-plus-lg"></i> Tambah Transaksi</button>
</div>

<div class="card">
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead>
          <tr>
            <th>Tanggal</th>
            <th>Uang Masuk</th>
            <th>Modal</th>
            <th>Margin</th>
            <th class="text-center">Aksi</th>
          </tr>
        </thead>
        <tbody>
          <% if(finances.length === 0) { %>
            <tr><td colspan="5">
              <div class="empty-state">
                <i class="bi bi-journal-text"></i>
                <p class="text-muted mb-0">Belum ada transaksi.</p>
              </div>
            </td></tr>
          <% } %>
          <% finances.forEach(f => { %>
          <tr>
            <td><span class="badge bg-light text-dark"><i class="bi bi-calendar3"></i> <%= f.tanggal %></span></td>
            <td class="fw-semibold text-success">Rp <%= Number(f.uang_masuk).toLocaleString('id-ID') %></td>
            <td>Rp <%= Number(f.modal).toLocaleString('id-ID') %></td>
            <td class="fw-bold text-info">Rp <%= Number(f.margin).toLocaleString('id-ID') %></td>
            <td class="text-center">
              <a href="/transactions/delete/<%= f.id %>" class="btn btn-sm btn-danger btn-action" onclick="return confirm('Hapus transaksi tanggal <%= f.tanggal %>?')" title="Hapus"><i class="bi bi-trash"></i></a>
            </td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<div class="modal fade" id="addModal">
  <div class="modal-dialog">
    <div class="modal-content">
      <form method="POST" action="/transactions">
        <div class="modal-header"><h5 class="modal-title"><i class="bi bi-plus-circle text-primary"></i> Transaksi Harian</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
        <div class="modal-body">
          <div class="mb-3">
            <label class="form-label">Tanggal</label>
            <input class="form-control" name="tanggal" type="date" value="<%= new Date().toISOString().split('T')[0] %>" required>
          </div>
          <div class="mb-3">
            <label class="form-label">Uang Masuk (Rp)</label>
            <input class="form-control" name="uang_masuk" type="number" step="0.01" placeholder="0" required>
          </div>
          <div class="mb-3">
            <label class="form-label">Modal (Rp)</label>
            <input class="form-control" name="modal" type="number" step="0.01" placeholder="0" required>
          </div>
          <div class="mb-2">
            <label class="form-label">Margin (Rp)</label>
            <input class="form-control" id="marginDisplay" type="text" value="Rp 0" disabled>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-light" data-bs-dismiss="modal">Batal</button>
          <button class="btn btn-primary"><i class="bi bi-check-lg"></i> Simpan</button>
        </div>
      </form>
    </div>
  </div>
</div>
<script>
document.addEventListener('input', function(e) {
  if (e.target.matches('input[name="uang_masuk"], input[name="modal"]')) {
    const uang = parseFloat(document.querySelector('input[name="uang_masuk"]').value) || 0;
    const modal = parseFloat(document.querySelector('input[name="modal"]').value) || 0;
    document.getElementById('marginDisplay').value = 'Rp ' + (uang - modal).toLocaleString('id-ID');
  }
});
</script>
<%- include('partials/footer') %>
