<%- include('partials/header') %>
<div class="page-header">
  <h4><i class="bi bi-file-earmark-bar-graph"></i> Laporan</h4>
  <span class="text-muted" style="font-size:0.8rem;"><i class="bi bi-info-circle"></i> Filter berdasarkan periode</span>
</div>

<div class="row g-3 mb-4">
  <div class="col-12">
    <div class="card">
      <div class="card-body">
        <div class="row g-2 align-items-end">
          <div class="col-6 col-md-3">
            <label class="form-label">Dari Tanggal</label>
            <input class="form-control" type="date" id="startDate">
          </div>
          <div class="col-6 col-md-3">
            <label class="form-label">Sampai Tanggal</label>
            <input class="form-control" type="date" id="endDate">
          </div>
          <div class="col-12 col-md-3">
            <button class="btn btn-primary w-100" onclick="loadReports()"><i class="bi bi-funnel"></i> Terapkan Filter</button>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="row g-3">
  <div class="col-md-4">
    <div class="card report-card">
      <div class="card-header">
        <h6 class="mb-0"><i class="bi bi-cart-check text-primary"></i> Laporan Penjualan</h6>
      </div>
      <div class="card-body p-0">
        <div class="table-responsive" style="max-height:320px">
          <table class="table table-sm table-hover mb-0">
            <thead><tr><th>Tanggal</th><th>Omzet</th><th>Laba</th></tr></thead>
            <tbody id="penjualanBody"></tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card report-card">
      <div class="card-header">
        <h6 class="mb-0"><i class="bi bi-arrow-return-left text-warning"></i> Laporan Retur</h6>
      </div>
      <div class="card-body p-0">
        <div class="table-responsive" style="max-height:320px">
          <table class="table table-sm table-hover mb-0">
            <thead><tr><th>Tanggal</th><th>Produk</th><th>Jml</th><th>Kerugian</th></tr></thead>
            <tbody id="returBody"></tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card report-card">
      <div class="card-header">
        <h6 class="mb-0"><i class="bi bi-pie-chart text-success"></i> Ringkasan Laba</h6>
      </div>
      <div class="card-body">
        <div class="d-flex justify-content-between mb-2 pb-2 border-bottom">
          <span class="text-muted">Omzet</span>
          <strong id="labaOmzet">Rp 0</strong>
        </div>
        <div class="d-flex justify-content-between mb-2 pb-2 border-bottom">
          <span class="text-muted">Modal</span>
          <strong id="labaModal">Rp 0</strong>
        </div>
        <div class="d-flex justify-content-between mb-2 pb-2 border-bottom">
          <span class="text-muted">Laba Kotor</span>
          <strong id="labaKotor" class="text-info">Rp 0</strong>
        </div>
        <div class="d-flex justify-content-between mb-2 pb-2 border-bottom">
          <span class="text-muted">Kerugian Retur</span>
          <strong id="labaKerugian" class="text-danger">Rp 0</strong>
        </div>
        <div class="d-flex justify-content-between pt-2">
          <span class="fw-bold">Laba Bersih</span>
          <strong id="labaBersih" class="text-success fs-5">Rp 0</strong>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
function loadReports() {
  const start = document.getElementById('startDate').value;
  const end = document.getElementById('endDate').value;
  const params = new URLSearchParams();
  if (start) params.append('start', start);
  if (end) params.append('end', end);

  fetch('/reports/penjualan?' + params.toString()).then(r => r.json()).then(data => {
    const tbody = document.getElementById('penjualanBody');
    tbody.innerHTML = data.map(d => `<tr><td>${d.tanggal}</td><td>Rp ${Number(d.total_omzet).toLocaleString('id-ID')}</td><td class="text-success">Rp ${Number(d.total_laba).toLocaleString('id-ID')}</td></tr>`).join('');
    if (!data.length) tbody.innerHTML = '<tr><td colspan="3" class="text-center text-muted py-3">Tidak ada data</td></tr>';
  });

  fetch('/reports/retur?' + params.toString()).then(r => r.json()).then(data => {
    const tbody = document.getElementById('returBody');
    tbody.innerHTML = data.map(d => `<tr><td>${d.tanggal_retur}</td><td>${d.product_name}</td><td>${d.jumlah}</td><td class="text-danger">-Rp ${Number(d.kerugian).toLocaleString('id-ID')}</td></tr>`).join('');
    if (!data.length) tbody.innerHTML = '<tr><td colspan="4" class="text-center text-muted py-3">Tidak ada data</td></tr>';
  });

  fetch('/reports/laba?' + params.toString()).then(r => r.json()).then(data => {
    document.getElementById('labaOmzet').textContent = 'Rp ' + Number(data.penjualan.omzet).toLocaleString('id-ID');
    document.getElementById('labaModal').textContent = 'Rp ' + Number(data.penjualan.modal).toLocaleString('id-ID');
    document.getElementById('labaKotor').textContent = 'Rp ' + Number(data.penjualan.laba).toLocaleString('id-ID');
    document.getElementById('labaKerugian').textContent = 'Rp ' + Number(data.retur.total_kerugian).toLocaleString('id-ID');
    document.getElementById('labaBersih').textContent = 'Rp ' + Number(data.labaBersih).toLocaleString('id-ID');
  });
}

loadReports();
</script>
<%- include('partials/footer') %>